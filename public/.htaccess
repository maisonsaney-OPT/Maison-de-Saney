# SPA rewrite, but NEVER rewrite real files (sitemap/robots/assets)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve existing files/directories as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, send everything to the SPA entry
  RewriteRule . /index.html [L]
</IfModule>

# Ensure correct MIME for sitemap
<IfModule mod_mime.c>
  AddType application/xml .xml
</IfModule>

